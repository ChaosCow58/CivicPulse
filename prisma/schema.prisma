generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

//////////////////////////////////////////////////////
// USER (Auth0-linked application profile)
//////////////////////////////////////////////////////

model User {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  auth0Id     String   @unique
  email       String
  username    String?

  role        String   @default("user")
  reputation  Int      @default(0)

  reports     Report[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

//////////////////////////////////////////////////////
// REPORTS (Citizen submissions)
//////////////////////////////////////////////////////
enum REPORT_TYPE {
  road_issue
  public_safety
  sanitation
  water_issue
  crime
  other
}

model Report {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId

  type      REPORT_TYPE
  severity  Int

  latitude  Float
  longitude Float

  userId    String   @db.ObjectId
  user      User     @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
}

//////////////////////////////////////////////////////
// HOTSPOTS (Computed clusters)
//////////////////////////////////////////////////////

model Hotspot {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId

  centerLat     Float
  centerLng     Float

  reportCount   Int
  avgSeverity   Float
  radiusMeters  Int

  updatedAt     DateTime @updatedAt
}

//////////////////////////////////////////////////////
// ANALYTICS CACHE (regression-js results)
//////////////////////////////////////////////////////

model Analytics {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId

  metric        String   // "report_trend", etc.
  value         Float
  metadata      String?  // JSON string if needed

  updatedAt     DateTime @updatedAt
}
