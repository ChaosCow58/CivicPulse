generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

//////////////////////////////////////////////////////
// USER (Auth0-linked application profile)
//////////////////////////////////////////////////////

model User {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  auth0Id     String   @unique
  email       String
  username    String?
  address     String?

  reputation  Int      @default(0)

  reports     Report[]
  comments    Comment[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

//////////////////////////////////////////////////////
// REPORTS (Citizen submissions)
//////////////////////////////////////////////////////
enum ReportType {
  ROAD_ISSUE
  PUBLIC_SAFETY
  SANITATION
  WATER_ISSUE
  CRIME
  OTHER
}

model Report {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId

  type      ReportType
  severity  Int
  votes     Int      @default(0)

  latitude  Float
  longitude Float

  userId    String   @db.ObjectId
  user      User     @relation(fields: [userId], references: [id])

  comments  Comment[]

  description String
  isResolved Boolean  @default(false)

  createdAt DateTime @default(now())
}

//////////////////////////////////////////////////////
// COMMENTS (Discussion on reports)
///////////////////////////////////////////////////////
model Comment {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId

  reportId  String   @db.ObjectId
  report    Report   @relation(fields: [reportId], references: [id])

  userId    String   @db.ObjectId
  user      User     @relation(fields: [userId], references: [id])

  content   String

  createdAt DateTime @default(now())
}
